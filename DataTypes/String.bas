Sub StringExample()

    '-------------------------------------------------------
    ' String Data Type
    '
    ' - Stores text (a sequence of characters).
    ' - Can contain letters, numbers, symbols, and spaces.
    ' - String values must be enclosed in double quotation marks.
    ' - Used for names, addresses, messages, file names,
    '   and any other textual information.
    '-------------------------------------------------------

    ' Declare a String variable
    Dim name As String

    ' Assign a text value
    name = "Amrit"

    ' Display the value in a message box
    MsgBox "Name: " & name

End Sub
