Sub IntegerExample()
    ' Integer Data Type
    ' - Stores whole numbers (no decimal values).
    ' - Size: 2 bytes
    ' - Range: -32,768 to 32,767

    ' Declare an Integer variable
    Dim age As Integer

    ' Assign a whole number to the variable
    age = 25

    ' Display the value in a message box
    MsgBox "Age: " & age

End Sub
