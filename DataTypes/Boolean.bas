Sub BooleanExample()
    '-------------------------------------------------------
    ' Boolean Data Type
    '
    ' - Stores only two values: True or False.
    ' - Size: 1 byte
    ' - Used to represent logical conditions or decisions.
    ' - Commonly used in If statements, loops, and flags
    '   to control the flow of a program.
    '-------------------------------------------------------

    ' Declare a Boolean variable
    Dim isLoggedIn As Boolean

    ' Assign a Boolean value
    isLoggedIn = True

    ' Display the value in a message box
    MsgBox "Is Logged In: " & isLoggedIn

End Sub
