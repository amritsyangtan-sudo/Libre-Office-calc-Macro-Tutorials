Sub DateExample()

    '-------------------------------------------------------
    ' Date Data Type
    '
    ' - Stores dates and times.
    ' - Can store a date, a time, or both.
    ' - Used for recording dates, scheduling events,
    '   calculating durations, and working with calendars.
    '-------------------------------------------------------

    ' Declare a Date variable
    Dim today As Date

    ' Assign the current system date
    today = Date

    ' Display the value in a message box
    MsgBox "Today's Date: " & today

End Sub
