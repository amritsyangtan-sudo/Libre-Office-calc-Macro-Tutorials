Sub DoubleExample()

    '-------------------------------------------------------
    ' Double Data Type
    '
    ' - Stores decimal (floating-point) numbers.
    ' - Size: 8 bytes
    ' - Provides high precision for decimal values.
    ' - Used for measurements, calculations, percentages,
    '   scientific values, and financial calculations that
    '   require decimal places.
    '-------------------------------------------------------

    ' Declare a Double variable
    Dim pi As Double

    ' Assign a decimal value
    pi = 3.14159265358979

    ' Display the value in a message box
    MsgBox "Pi: " & pi

End Sub
